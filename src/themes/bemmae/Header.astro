---
import type { NavItem } from './types';

interface Props {
  siteName: string;
  nav: NavItem[];
  logoSrc?: string;
}

const { siteName, nav, logoSrc } = Astro.props;
---
<header class="sticky top-0 z-50 w-full border-b border-[rgba(255,135,91,0.2)] bg-[#ff875b] shadow-[0_1px_0_rgba(0,0,0,0.06)]">
  <div class="max-w-4xl mx-auto px-4 py-2.5 sm:py-3 flex items-center gap-3 md:gap-4">
    <a href="/" class="flex items-center min-h-[40px] shrink-0" aria-label={siteName}>
      {logoSrc ? (
        <img
          src={logoSrc}
          alt=""
          width="480"
          height="120"
          class="h-10 w-auto sm:h-11 md:h-12 max-h-[3.25rem] sm:max-h-[3.5rem] md:max-h-16 max-w-[min(88vw,20rem)] sm:max-w-[min(85vw,22rem)] object-contain object-left"
          decoding="async"
          fetchpriority="low"
        />
      ) : (
        <span class="text-base font-semibold text-white">{siteName}</span>
      )}
    </a>
    <form
      method="get"
      action="/blog"
      class="hidden md:flex flex-1 justify-end min-w-0 max-w-sm lg:max-w-md"
      role="search"
      aria-label="Buscar no blog"
    >
      <div class="flex w-full rounded-lg overflow-hidden border border-white/35 bg-white/10 shadow-sm focus-within:border-white/60 focus-within:bg-white/15">
        <label for="bem-header-search" class="sr-only">Buscar artigos</label>
        <input
          id="bem-header-search"
          type="search"
          name="q"
          enterkeyhint="search"
          placeholder="Buscar no blog…"
          autocomplete="off"
          class="min-w-0 flex-1 border-0 bg-transparent px-3 py-2 text-sm text-white placeholder:text-white/65 focus:outline-none focus:ring-0"
        />
        <button
          type="submit"
          class="shrink-0 px-3 text-white hover:bg-white/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/80"
          aria-label="Buscar"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>
      </div>
    </form>
    <nav class="hidden md:flex items-center gap-0.5 shrink-0" aria-label="Navegação">
      {nav.map((item) => (
        <a
          href={item.href}
          class="text-sm font-semibold text-white no-underline hover:bg-white/15 rounded-md px-3 min-h-[40px] flex items-center"
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="flex-1 md:hidden" aria-hidden="true" />
    <button type="button" id="bem-mobile-menu-btn" class="md:hidden p-2 min-h-[40px] min-w-[40px] flex items-center justify-center text-white rounded-md hover:bg-white/15 shrink-0" aria-label="Abrir menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
    </button>
  </div>
  <div id="bem-mobile-menu" class="md:hidden hidden border-t border-white/20 bg-[#ff875b] px-4 py-3">
    <form method="get" action="/blog" class="mb-3 flex gap-2" role="search" aria-label="Buscar no blog" id="bem-mobile-search-form">
      <label for="bem-mobile-search" class="sr-only">Buscar artigos</label>
      <input
        id="bem-mobile-search"
        type="search"
        name="q"
        enterkeyhint="search"
        placeholder="Buscar no blog…"
        autocomplete="off"
        class="min-w-0 flex-1 rounded-lg border border-white/35 bg-white/10 px-3 py-2 text-sm text-white placeholder:text-white/65 focus:border-white/60 focus:outline-none focus:ring-2 focus:ring-white/40"
      />
      <button
        type="submit"
        class="shrink-0 rounded-lg bg-white/20 px-3 py-2 text-white hover:bg-white/30"
        aria-label="Buscar"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </button>
    </form>
    <nav class="flex flex-col gap-1">
      {nav.map((item) => (
        <a
          href={item.href}
          class="bem-mobile-nav-link py-2.5 min-h-[44px] flex items-center text-sm font-semibold text-white no-underline hover:bg-white/15 rounded-md px-2"
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
<script>
  const mobileMenu = document.getElementById('bem-mobile-menu');
  document.getElementById('bem-mobile-menu-btn')?.addEventListener('click', () => mobileMenu?.classList.toggle('hidden'));
  document.querySelectorAll('.bem-mobile-nav-link').forEach((link) => link.addEventListener('click', () => mobileMenu?.classList.add('hidden')));
  document.getElementById('bem-mobile-search-form')?.addEventListener('submit', () => mobileMenu?.classList.add('hidden'));
</script>
