---
/**
 * Rodapé Bem Mãe — três colunas, isenção em destaque, JSON-LD da organização.
 */
import type { NavItem } from './types';
import { readSingleton } from '../../utils/singleton-utils';
import { readSiteSettings, resolvePublicSiteUrl, schemaPageUrl } from '../../utils/read-site-settings';
import { getSiteContactInfo } from '../../utils/site-contact';

interface Props {
  siteName: string;
  footerNav: NavItem[];
  /** Pasta de singletons (ex.: bemmae) */
  contentThemeId?: string;
}

const { siteName, footerNav, contentThemeId = 'bemmae' } = Astro.props;

const footer = (await readSingleton('footer', contentThemeId)) || {};
const contactData = (await readSingleton('contact', contentThemeId)) || {};
const settings = await readSiteSettings();
const { phone: phoneDigits } = await getSiteContactInfo();

const tagline = String(footer.tagline || footer.description || '').trim();
const socialLinks = (Array.isArray((footer as { socialLinks?: { platform: string; url: string; icon?: string }[] }).socialLinks)
  ? (footer as { socialLinks: { platform: string; url: string; icon?: string }[] }).socialLinks
  : []) as { platform: string; url: string; icon?: string }[];

const orgLegalName = String(footer.organizationLegalName || siteName).trim();
const addressLine = String(footer.addressLine || '').trim();
const city = String(footer.city || '').trim();
const state = String(footer.state || '').trim();
const postalCode = String(footer.postalCode || '').trim();
const country = String(footer.country || 'Brasil').trim();

const email =
  String(
    (contactData as Record<string, string>).email || (footer as Record<string, string>).contactEmail || '',
  ).trim();

const addressLocality = [city, state].filter(Boolean).join(' · ');
const streetAddress = addressLine;
const hasPostalAddress = streetAddress || addressLocality || postalCode;

const canonicalBase = resolvePublicSiteUrl(settings.canonicalUrl as string | undefined, Astro.url.origin);

const affiliateNote = String(
  (footer as { affiliateTransparencyNote?: string }).affiliateTransparencyNote || '',
).trim();

const footerLogoSrc = String((footer as { logoImage?: string }).logoImage || '').trim();

const orgJsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: orgLegalName,
  url: schemaPageUrl(canonicalBase),
  description: tagline || undefined,
};

if (email) (orgJsonLd as any).email = email;
if (phoneDigits) (orgJsonLd as any).telephone = `+55${phoneDigits}`;

if (hasPostalAddress) {
  (orgJsonLd as any).address = {
    '@type': 'PostalAddress',
    streetAddress: streetAddress || undefined,
    addressLocality: city || undefined,
    addressRegion: state || undefined,
    postalCode: postalCode || undefined,
    addressCountry: country === 'Brasil' ? 'BR' : country,
  };
}

const sameAsUrls = socialLinks.map((s) => String(s.url || '').trim()).filter(Boolean);
if (sameAsUrls.length) (orgJsonLd as any).sameAs = sameAsUrls;

const socialOrder = ['youtube', 'pinterest'];
const socialForColumn = [...socialLinks]
  .filter((s) => {
    const icon = String(s.icon || '').toLowerCase();
    return icon === 'youtube' || icon === 'pinterest';
  })
  .sort(
    (a, b) =>
      socialOrder.indexOf(String(a.icon || '').toLowerCase()) -
      socialOrder.indexOf(String(b.icon || '').toLowerCase()),
  );

/** Mesma tipografia e leading para alinhar marca, Navegação e Social na mesma linha de topo. */
const footerHeadingBase =
  'font-sans text-xs font-semibold tracking-[0.12em] text-[#2d2d2d] leading-none';
const footerBrandHeadingClass = footerHeadingBase;
const footerColHeadingClass = `${footerHeadingBase} uppercase`;
const navLinkClass =
  'block text-[15px] font-sans font-normal text-[#666666] hover:text-[#2d2d2d] transition-colors py-2 leading-snug';
const disclaimerBodyClass = 'text-[13px] leading-[1.65] text-[#666666] font-sans text-pretty';
---

<footer class="mt-20 border-t border-[#e8e8e8] bg-[var(--color-bg)] font-sans">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16 md:py-20">
    <div class="flex flex-col gap-12 lg:flex-row lg:items-start lg:gap-10 xl:gap-12">
      <!-- Coluna 1: marca + descrição + nota de afiliados (largura máx. fixa) -->
      <div class="flex w-full max-w-[280px] shrink-0 flex-col lg:w-auto">
        <a
          href="/"
          class="inline-block min-w-0 no-underline hover:opacity-80 transition-opacity"
          aria-label={orgLegalName}
        >
          {footerLogoSrc ? (
            <img
              src={footerLogoSrc}
              alt={orgLegalName}
              width="140"
              height="40"
              loading="lazy"
              decoding="async"
              class="h-10 w-auto object-contain"
            />
          ) : (
            <span class:list={[footerBrandHeadingClass]}>{orgLegalName}</span>
          )}
        </a>
        <div class="mt-6 flex min-w-0 flex-col">
          {tagline && (
            <p class="text-[15px] leading-[1.65] text-[#666666]">
              {tagline}
            </p>
          )}
          {affiliateNote && (
            <div class="mt-[15px] max-w-[min(260px,100%)] border-l-2 border-[#d4d4d4] pl-3 md:pl-4">
              <p class="text-[11px] leading-[1.4] text-[#9a9a9a] text-pretty">
                {affiliateNote}
              </p>
            </div>
          )}
        </div>
      </div>

      <!-- Coluna 2: navegação (preenche o espaço restante) -->
      <div class="flex min-w-0 flex-1 flex-col basis-0">
        <h2 class:list={[footerColHeadingClass, 'm-0']}>Navegação</h2>
        <nav class="mt-6 flex flex-col gap-0.5" aria-label="Links do rodapé">
          {footerNav.map((item) => (
            <a href={item.href} class={navLinkClass}>
              {item.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Coluna 3: social -->
      <div class="flex min-w-0 flex-1 flex-col basis-0">
        <h2 class:list={[footerColHeadingClass, 'm-0']}>Social</h2>
        {socialForColumn.length > 0 ? (
          <div class="mt-6 flex flex-wrap gap-3" aria-label="Redes sociais">
            {socialForColumn.map((s) => (
              <a
                href={s.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-[#e0e0e0] bg-white text-[#444444] hover:border-[#cccccc] hover:bg-[#fafafa] transition-colors"
                aria-label={s.platform}
                title={s.platform}
              >
                {s.icon === 'youtube' ? (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-[18px] w-[18px]" aria-hidden="true">
                    <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
                  </svg>
                ) : s.icon === 'pinterest' ? (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-[18px] w-[18px]" aria-hidden="true">
                    <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z" />
                  </svg>
                ) : (
                  <span class="text-[10px] font-medium">{s.platform}</span>
                )}
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-6 text-[13px] text-[#888888]">Configure YouTube e Pinterest em footer.yaml.</p>
        )}
      </div>
    </div>

    <!-- Caixa de isenção -->
    <section
      class="mt-16 md:mt-20 mx-auto max-w-[900px] rounded-2xl border border-[#ebebeb] bg-[#f9f9f9] p-[30px]"
      aria-labelledby="footer-disclaimer-heading"
    >
      <div class="flex items-start gap-3 md:gap-4">
        <span
          class="mt-2 h-2 w-2 shrink-0 rounded-full bg-orange-500"
          aria-hidden="true"
        />
        <div class="min-w-0 flex-1 space-y-4">
          <h2 id="footer-disclaimer-heading" class="text-base font-semibold text-[#2d2d2d] font-sans leading-snug">
            Nota de Isenção de Responsabilidade
          </h2>
          <p class={disclaimerBodyClass}>
            As informações publicadas no {orgLegalName} têm caráter exclusivamente informativo e educacional.
            Elas não substituem consulta, diagnóstico ou orientação de médico, pediatra ou outro profissional de saúde
            habilitado. Para qualquer dúvida sobre saúde da criança, medicamentos ou uso de equipamentos de segurança,
            procure sempre um profissional qualificado.
          </p>
        </div>
      </div>
    </section>

    <!-- Barra inferior -->
    <div class="mt-12 md:mt-14 pt-8 border-t border-[#e5e5e5]">
      <p class="text-sm text-[#666666] text-left font-sans">
        © {new Date().getFullYear()} {orgLegalName}
      </p>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
</footer>
