---
import type { CollectionEntry } from 'astro:content';
import { getPostUrl, type BlogPermalinkStructure, type BlogUrlPrefix } from '../../utils/blog-permalink';
import { resolveBemmaeMediaUrl, rewriteBemmaeContentImagesInHtml } from '../../utils/media-url';
import { demoteBodyH1ToH2, replaceProductBoxTitleH2WithDiv } from '../../utils/post-html-sanitize';
import { splitReviewRoundupBodyParagraphs } from '../../utils/review-paragraph-split';
import { injectH2IdsAndBuildToc, splitHtmlAfterReviewHeroPicks } from '../../utils/review-article-toc';
import { injectMissingProsConsCtas } from '../../utils/review-pros-cons-cta';
import { ensureRoundupTableHead, upgradeRoundupItemsHtml } from '../../utils/review-roundup-rows';
import type { BemmaeExpertCardData } from '../../utils/bemmae-article-experts';
import BemmaeExpertCard from './BemmaeExpertCard.astro';
import { extractFirstRoundup } from '../../utils/extract-roundup';

interface Props {
  post: any;
  author: any;
  Content?: any;
  /** Corpo HTML (import Ghost / contentFormat: html); ignora Content. */
  htmlContent?: string | null;
  relatedPosts?: CollectionEntry<'posts'>[];
  blogPermalinkStructure?: BlogPermalinkStructure;
  blogUrlPrefix?: BlogUrlPrefix;
  /** Especialistas no fim do post (about.yaml + autor); se omitido, usa o bloco antigo só com `author`. */
  articleExperts?: BemmaeExpertCardData[];
  articleExpertsSectionTitle?: string;
}

const {
  post,
  author,
  Content,
  htmlContent,
  relatedPosts: relatedPostsProp,
  blogPermalinkStructure = 'postname',
  blogUrlPrefix = 'blog',
  articleExperts,
  articleExpertsSectionTitle = 'Conheça nossos especialistas',
} = Astro.props;
const relatedPosts = relatedPostsProp ?? [];
const date = post.data.publishedDate;
const layoutVariant = post.data.articleLayout ?? 'default';
const isReviewRoundup = layoutVariant === 'reviewRoundup';
const heroImage = resolveBemmaeMediaUrl(post.data.thumbnail || post.data.metaImage);
const htmlBody = htmlContent
  ? (() => {
      let html = demoteBodyH1ToH2(rewriteBemmaeContentImagesInHtml(htmlContent));
      html = replaceProductBoxTitleH2WithDiv(html);
      if (isReviewRoundup) html = splitReviewRoundupBodyParagraphs(html);
      return html;
    })()
  : null;

let postHtmlBody = htmlBody;
let reviewTocItems: { id: string; text: string }[] = [];
let reviewBodySplit: { head: string; tail: string } | null = null;
if (htmlBody && htmlBody.includes('cnx-aff-roundup')) {
  let h = upgradeRoundupItemsHtml(htmlBody);
  h = ensureRoundupTableHead(h);
  postHtmlBody = h;
}
if (isReviewRoundup && postHtmlBody) {
  const tocResult = injectH2IdsAndBuildToc(postHtmlBody);
  postHtmlBody = injectMissingProsConsCtas(tocResult.html);
  reviewTocItems = tocResult.toc;
  reviewBodySplit = splitHtmlAfterReviewHeroPicks(postHtmlBody);
}

/**
 * Cartão de produto, prós/contras e títulos de review usam CSS em article-review-roundup.css
 * sob o ancestral `.article-review-roundup`. Antes só existia em posts com layout "reviewRoundup",
 * por isso o mesmo HTML no layout default parecia "versão antiga" (só o ranking parecia certo).
 */
const applyRoundupArticleScope =
  isReviewRoundup || (!!postHtmlBody && /\bcnx-aff-/.test(postHtmlBody));

const hideHero = !!post.data.hideThumbnail;
let heroRoundupHtml = '';
if (hideHero && isReviewRoundup && reviewBodySplit) {
  // Extrai o roundup do tail (onde ele sempre está no nosso layout sem review-hero-picks)
  const extracted = extractFirstRoundup(reviewBodySplit.tail);
  if (extracted.roundupHtml) {
    heroRoundupHtml = extracted.roundupHtml;
    reviewBodySplit = { head: reviewBodySplit.head, tail: extracted.remainingHtml };
  }
}
---
<article
  class:list={[
    'mx-auto py-10 sm:py-12',
    applyRoundupArticleScope ? 'px-4 sm:px-6 max-w-3xl article-review-roundup' : 'px-4 sm:px-6',
    !applyRoundupArticleScope && (htmlContent ? 'max-w-3xl' : 'max-w-2xl'),
  ]}
>
  <header class:list={[isReviewRoundup ? 'mb-5 md:mb-6' : 'mb-8 md:mb-10']}>
    <nav class="text-sm text-[var(--color-muted)] mb-3 md:mb-3.5 leading-snug" aria-label="Navegação do artigo">
      <a href="/" class="text-[var(--color-muted)] hover:text-[var(--color-link)] no-underline transition-colors">Início</a>
      <span class="mx-1.5 opacity-60 select-none" aria-hidden="true">›</span>
      <span class="text-[var(--color-dark)] font-medium">{post.data.title}</span>
    </nav>
    <h1
      class="text-2xl md:text-5xl font-extrabold tracking-tight text-[var(--color-heading)] leading-[1.2] [font-family:var(--font-heading)] mb-4"
    >
      {post.data.title}
    </h1>
  </header>
  {heroImage && !hideHero && (
    <div
      class:list={[
        'post-hero-image-wrap flex items-center justify-center',
        isReviewRoundup ? 'mb-5 md:mb-6' : 'mb-8',
      ]}
    >
      <img
        src={heroImage}
        alt=""
        width={900}
        height={600}
        class="post-hero-image"
        sizes="(max-width: 896px) 100vw, 832px"
        fetchpriority="high"
        loading="eager"
        decoding="async"
      />
    </div>
  )}
  {heroRoundupHtml && (
    <div class="hero-roundup mb-5 md:mb-6">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-[var(--color-heading)] [font-family:var(--font-heading)] mb-4">Produtos em Destaque</h2>
      <div set:html={heroRoundupHtml} />
    </div>
  )}
  {(author || date) && (
    <div
      class:list={[
        'flex items-start gap-3 sm:gap-3.5',
        isReviewRoundup ? 'mb-6 md:mb-7 pb-6 md:pb-7 border-b border-orange-200/70' : 'mb-8 md:mb-10',
      ]}
    >
      {author ? (
        <>
          {author.data.avatar ? (
            <img
              src={resolveBemmaeMediaUrl(author.data.avatar)}
              alt=""
              width="48"
              height="48"
              class="w-11 h-11 sm:w-12 sm:h-12 rounded-full object-cover shrink-0 border border-[var(--color-border)] bg-white"
              loading="eager"
              decoding="async"
            />
          ) : (
            <div
              class="w-11 h-11 sm:w-12 sm:h-12 rounded-full shrink-0 flex items-center justify-center text-sm font-semibold text-[var(--color-heading)] bg-[var(--color-surface)] border border-[var(--color-border)]"
              aria-hidden="true"
            >
              {String(author.data.name || '?')
                .trim()
                .charAt(0)
                .toUpperCase()}
            </div>
          )}
          <div class="min-w-0 pt-0.5">
            <div class="font-bold text-[var(--color-heading)] text-base sm:text-[1.0625rem] leading-snug">{author.data.name}</div>
            {date && (
              <time class="mt-1 block text-sm text-[var(--color-muted)]" datetime={date}>
                {new Date(date).toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric' })}
              </time>
            )}
          </div>
        </>
      ) : (
        date && (
          <time class="text-sm text-[var(--color-muted)]" datetime={date}>
            {new Date(date).toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric' })}
          </time>
        )
      )}
    </div>
  )}
  <div
    class:list={[
      'post-content max-w-none text-[var(--color-dark)]',
      !htmlContent &&
        'prose prose-neutral prose-lg max-w-none prose-p:text-lg prose-p:leading-relaxed prose-p:mb-8 prose-p:text-[var(--color-dark)] prose-headings:[font-family:var(--font-heading)] prose-headings:font-bold prose-headings:text-[var(--color-heading)] prose-h1:text-2xl md:prose-h1:text-5xl prose-h1:font-extrabold prose-h1:tracking-tight prose-h1:mb-4 prose-h1:mt-8 prose-h2:text-3xl md:prose-h2:text-4xl prose-h2:tracking-tighter prose-h2:font-bold prose-h2:mt-8 prose-h2:mb-4 prose-h3:text-lg md:prose-h3:text-xl prose-h3:mt-6 prose-h3:mb-3 prose-h4:text-lg prose-h4:mt-6 prose-h4:mb-3 prose-h5:text-base prose-h5:font-semibold prose-h5:mt-6 prose-h5:mb-3 prose-h6:text-[0.8125rem] prose-h6:uppercase prose-h6:tracking-wide prose-h6:font-semibold prose-h6:text-[#64748b] prose-h6:mt-6 prose-h6:mb-3 prose-li:my-2 prose-a:font-medium prose-a:text-[var(--color-link)] prose-a:underline hover:prose-a:text-[var(--color-link-hover)]',
    ]}
  >
    {postHtmlBody ? (
      isReviewRoundup && reviewBodySplit ? (
        <>
          {reviewBodySplit.head ? <div class="bemmae-post-html post-content" set:html={reviewBodySplit.head} /> : null}
          {reviewTocItems.length > 0 && (
            <details class="review-article-toc">
              <summary class="review-article-toc-summary">
                <span class="review-article-toc-title">Índice do Artigo</span>
                <span class="review-article-toc-chevron" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 9l6 6 6-6" />
                  </svg>
                </span>
              </summary>
              <nav class="review-article-toc-nav" aria-label="Seções do artigo">
                <ul class="review-article-toc-list">
                  {reviewTocItems.map((item) => (
                    <li>
                      <a href={`#${item.id}`} class="review-article-toc-link">
                        {item.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </details>
          )}
          <div class="bemmae-post-html post-content" set:html={reviewBodySplit.tail} />
        </>
      ) : (
        <div class="bemmae-post-html post-content" set:html={postHtmlBody} />
      )
    ) : (
      Content && <Content />
    )}
  </div>

  {articleExperts && articleExperts.length > 0 ? (
    <section class="mt-12 pt-10 border-t border-[var(--color-border)]" aria-labelledby="post-experts-heading">
      <h2
        id="post-experts-heading"
        class="text-3xl font-bold text-[var(--color-heading)] mb-8 text-center sm:text-left [font-family:var(--font-heading)] tracking-tight"
      >
        {articleExpertsSectionTitle}
      </h2>
      <ul class="flex flex-col gap-8 list-none p-0 m-0">
        {articleExperts.map((ex) => (
          <li>
            <BemmaeExpertCard {...ex} />
          </li>
        ))}
      </ul>
    </section>
  ) : (
    author && (
      <section class="mt-12 pt-10 border-t border-[var(--color-border)]" aria-labelledby="post-author-heading">
        <div class="flex flex-col sm:flex-row gap-5 sm:gap-6 items-start rounded-2xl bg-[var(--color-rosa)] p-5 md:p-6">
          {author.data.avatar ? (
            <img
              src={resolveBemmaeMediaUrl(author.data.avatar)}
              alt={author.data.name}
              width="72"
              height="72"
              class="w-16 h-16 sm:w-[4.5rem] sm:h-[4.5rem] rounded-full object-cover shrink-0 border border-[var(--color-border)] bg-white"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <div
              class="w-16 h-16 sm:w-[4.5rem] sm:h-[4.5rem] rounded-full shrink-0 flex items-center justify-center text-lg font-semibold text-[var(--color-heading)] bg-white border border-[var(--color-border)]"
              aria-hidden="true"
            >
              {String(author.data.name || '?')
                .trim()
                .charAt(0)
                .toUpperCase()}
            </div>
          )}
          <div class="min-w-0 flex-1">
            <p class="text-[0.7rem] font-semibold uppercase tracking-wider text-[var(--color-muted)] mb-1">Autora</p>
            <div id="post-author-heading" class="text-lg font-bold text-[var(--color-heading)] leading-snug">
              {author.data.name}
            </div>
            {author.data.role && (
              <p class="mt-0.5 text-sm text-[var(--color-muted)]">{author.data.role}</p>
            )}
            {author.data.bio && (
              <p class="mt-3 text-sm text-[var(--color-muted)] leading-relaxed">{author.data.bio}</p>
            )}
            <a
              href={`/authors/${author.id}`}
              class="inline-flex items-center gap-1.5 mt-4 text-sm font-semibold text-[var(--color-link)] no-underline hover:underline min-h-[44px]"
            >
              Ver perfil completo
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </section>
    )
  )}

  {relatedPosts.length > 0 && (
    <section
      class:list={[
        'mt-12 pt-10 border-t',
        isReviewRoundup ? 'border-[rgba(255,135,91,0.35)]' : 'border-[var(--color-border)]',
      ]}
      aria-labelledby="related-posts-heading"
    >
      <h2
        id="related-posts-heading"
        class="text-3xl md:text-4xl font-bold tracking-tighter text-[var(--color-heading)] [font-family:var(--font-heading)] mb-2"
      >
        Posts relacionados
      </h2>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6 mt-6">
        {relatedPosts.map((rp) => {
          const url = getPostUrl(rp, blogPermalinkStructure, blogUrlPrefix);
          const thumb = resolveBemmaeMediaUrl(rp.data.thumbnail || rp.data.metaImage);
          const rDate = rp.data.publishedDate;
          return (
            <a
              href={url}
              class="group block rounded-lg border border-[var(--color-border)] bg-white overflow-hidden hover:border-[var(--color-link)] transition-colors shadow-sm"
            >
              {thumb ? (
                <div class="aspect-[4/3] overflow-hidden bg-[var(--color-surface)]">
                  <img
                    src={thumb}
                    alt=""
                    class="w-full h-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              ) : (
                <div class="aspect-[4/3] bg-[var(--color-surface)] flex items-center justify-center text-[var(--color-muted)] text-sm">
                  Sem capa
                </div>
              )}
              <div class="p-4">
                {rDate && (
                  <time class="text-xs text-[var(--color-muted)]" datetime={rDate}>
                    {new Date(rDate).toLocaleDateString('pt-BR')}
                  </time>
                )}
                <h3 class="mt-1 text-base font-semibold text-[var(--color-heading)] group-hover:text-[var(--color-link)] leading-snug">
                  {rp.data.title}
                </h3>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}
</article>

<script>
  const CHEVRON_LEFT = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>`;
  const CHEVRON_RIGHT = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>`;

  function initRoundupSliders() {
    document.querySelectorAll('.cnx-aff-roundup').forEach(roundup => {
      if (roundup.dataset.sliderInit) return;
      roundup.dataset.sliderInit = '1';

      const head = roundup.querySelector('.cnx-aff-roundup-head');
      const items = [...roundup.querySelectorAll(':scope > .cnx-aff-roundup-item')];
      if (items.length < 2) return;

      if (head) head.hidden = true;

      const track = document.createElement('div');
      track.className = 'cnx-aff-roundup-track';
      track.setAttribute('role', 'list');
      items.forEach(item => {
        item.setAttribute('role', 'listitem');
        track.appendChild(item);
      });
      roundup.appendChild(track);

      const wrap = document.createElement('div');
      wrap.className = 'cnx-aff-roundup-slider-wrap';
      roundup.parentNode.insertBefore(wrap, roundup);
      wrap.appendChild(roundup);

      const prevBtn = document.createElement('button');
      prevBtn.type = 'button';
      prevBtn.className = 'cnx-aff-slider-btn cnx-aff-slider-btn--prev';
      prevBtn.setAttribute('aria-label', 'Produto anterior');
      prevBtn.innerHTML = CHEVRON_LEFT;
      prevBtn.setAttribute('aria-disabled', 'true');

      const nextBtn = document.createElement('button');
      nextBtn.type = 'button';
      nextBtn.className = 'cnx-aff-slider-btn cnx-aff-slider-btn--next';
      nextBtn.setAttribute('aria-label', 'Próximo produto');
      nextBtn.innerHTML = CHEVRON_RIGHT;

      const updateButtons = () => {
        const atStart = track.scrollLeft <= 2;
        const atEnd = track.scrollLeft + track.clientWidth >= track.scrollWidth - 2;
        prevBtn.setAttribute('aria-disabled', String(atStart));
        nextBtn.setAttribute('aria-disabled', String(atEnd));
      };

      const scroll = (dir) => {
        const cardW = track.querySelector('.cnx-aff-roundup-item')?.offsetWidth || 195;
        const gap = 12;
        track.scrollBy({ left: dir * (cardW + gap), behavior: 'smooth' });
      };

      prevBtn.addEventListener('click', () => scroll(-1));
      nextBtn.addEventListener('click', () => scroll(1));
      track.addEventListener('scroll', updateButtons, { passive: true });

      wrap.appendChild(prevBtn);
      wrap.appendChild(nextBtn);

      // Estado inicial dos botões após o layout estabilizar
      requestAnimationFrame(updateButtons);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initRoundupSliders);
  } else {
    initRoundupSliders();
  }
</script>
