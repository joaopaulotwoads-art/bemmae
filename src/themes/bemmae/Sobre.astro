---
import { resolveBemmaeMediaUrl } from '../../utils/media-url';

interface Props {
  data: Record<string, any>;
}

const { data: d } = Astro.props;

const team = Array.isArray(d.teamMembers) ? d.teamMembers : [];

const valuesTitle = String(d.valuesTitle || 'Nossos valores').trim();
const values = Array.isArray(d.values) && d.values.length > 0 ? d.values : defaultValues();

const processTitle = String(d.processTitle || 'Nosso processo de análise').trim();
const processSteps =
  Array.isArray(d.processSteps) && d.processSteps.length > 0 ? d.processSteps : defaultProcessSteps();

const teamSectionTitle = String(d.teamSectionTitle || 'Nossa equipe').trim();

const ctaBannerTitle = String(d.ctaBannerTitle || '').trim() || 'Pronta para escolher com mais calma?';
const ctaBannerText =
  String(d.ctaBannerText || '').trim() ||
  'Explore os guias sobre carrinhos, cadeiras e enxoval e decida com informação clara, sem pressa de loja.';
const ctaPrimaryText = String(d.ctaPrimaryText || d.ctaLinkText || 'Ver guias').trim();
const ctaPrimaryHref = String(d.ctaPrimaryHref || d.ctaLinkHref || '/carrinhos-de-bebe').trim();
const ctaSecondaryText = String(d.ctaSecondaryText || '').trim();
const ctaSecondaryHref = String(d.ctaSecondaryHref || '').trim();

const disclaimer = String(d.disclaimer || '').trim();

function defaultValues() {
  return [
    {
      icon: '⚖️',
      title: 'Avaliação com pé no chão',
      description:
        'Textos pensados para quem compra no Brasil. Peso, Inmetro, porta-malas e calçada entram na conversa, não só foto bonita de catálogo.',
    },
    {
      icon: '🔍',
      title: 'Pesquisa antes de publicar',
      description:
        'Leio ficha, manual e reclamações recorrentes antes de recomendar. Quando algo depende do anúncio ou do lote, deixo isso explícito no artigo.',
    },
    {
      icon: '💬',
      title: 'Linguagem acessível',
      description:
        'Explico termos técnicos quando aparecem e evito julgar a escolha da família. O objetivo é clareza para mães, pais e cuidadores.',
    },
  ];
}

function defaultProcessSteps() {
  return [
    {
      title: 'Definição do tema',
      body: 'Escolho assuntos que aparecem de verdade na vida de quem tem bebê pequeno, de carrinho compacto a travel system e cadeira para auto.',
    },
    {
      title: 'Cruzamento de informação',
      body: 'Reúno dados de fabricante, selo quando há, medidas e relatos de uso para não depender só do marketing.',
    },
    {
      title: 'Redação do guia',
      body: 'Organizo prós, contras e perguntas que costumam surgir na hora de clicar em comprar ou ir à loja.',
    },
    {
      title: 'Atualização quando faz sentido',
      body: 'Quando linha muda de nome, preço ou kit, volto ao texto para alinhar o que o leitor encontra hoje no varejo.',
    },
  ];
}
---

<div class="bemmae-sobre">
  <!-- Hero -->
  <section class="relative px-4 sm:px-6 pt-10 pb-14 md:pt-14 md:pb-20 text-center border-b border-[var(--color-border)] bg-[var(--color-bg)]">
    <div class="max-w-3xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-accent)] mb-3">Sobre</p>
      <h1 class="text-3xl sm:text-4xl md:text-[2.5rem] font-extrabold text-[var(--color-heading)] leading-tight">
        {d.heroTitle || 'Sobre o Bem Mãe'}
      </h1>
      {d.heroSubtitle && (
        <p class="mt-5 text-lg md:text-xl text-[var(--color-text)] leading-relaxed">
          {d.heroSubtitle}
        </p>
      )}
    </div>
    {d.heroImage && (
      <div class="max-w-4xl mx-auto mt-10 rounded-2xl overflow-hidden shadow-md ring-1 ring-[var(--color-border)]">
        <img
          src={resolveBemmaeMediaUrl(String(d.heroImage).trim()) || String(d.heroImage).trim()}
          alt=""
          class="w-full h-auto object-cover max-h-[400px]"
          loading="lazy"
        />
      </div>
    )}
    {!d.heroImage && d.heroImagePlaceholder && (
      <div
        class="max-w-4xl mx-auto mt-10 aspect-[16/9] rounded-2xl bg-[var(--color-surface)] flex items-center justify-center text-[var(--color-muted)] text-sm ring-1 ring-[var(--color-border)]"
      >
        {d.heroImagePlaceholder}
      </div>
    )}
  </section>

  <!-- Valores -->
  <section class="px-4 sm:px-6 py-14 md:py-20 bg-[var(--color-surface)]" aria-labelledby="sobre-valores">
    <div class="max-w-6xl mx-auto">
      <h2 id="sobre-valores" class="text-2xl md:text-3xl font-bold text-center text-[var(--color-heading)] mb-12">
        {valuesTitle}
      </h2>
      <div class="grid md:grid-cols-3 gap-8 md:gap-10">
        {values.map((v: any) => (
          <div class="rounded-2xl border border-[var(--color-border)] bg-white p-8 shadow-sm text-center md:text-left">
            <div class="text-3xl mb-4" aria-hidden="true">{v.icon || '✨'}</div>
            <h3 class="text-lg font-bold text-[var(--color-heading)] mb-3">{v.title}</h3>
            <p class="text-[var(--color-muted)] leading-relaxed text-[17px]">{v.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Processo -->
  <section class="px-4 sm:px-6 py-14 md:py-20 bg-[var(--color-bg)]" aria-labelledby="sobre-processo">
    <div class="max-w-3xl mx-auto">
      <h2 id="sobre-processo" class="text-2xl md:text-3xl font-bold text-[var(--color-heading)] mb-12 text-center">
        {processTitle}
      </h2>
      <ol class="space-y-10">
        {processSteps.map((step: any, i: number) => (
          <li class="flex gap-5 md:gap-6">
            <div
              class="shrink-0 w-11 h-11 md:w-12 md:h-12 rounded-full bg-[var(--color-accent)] text-white font-bold flex items-center justify-center text-lg shadow-sm"
              aria-hidden="true"
            >
              {i + 1}
            </div>
            <div class="min-w-0 pt-0.5">
              <h3 class="text-lg font-bold text-[var(--color-heading)] mb-2">{step.title}</h3>
              <p class="text-[var(--color-muted)] leading-relaxed text-[17px]">{step.body || step.description}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Corpo / história -->
  {d.body && (
    <section class="px-4 sm:px-6 py-14 md:py-16 border-t border-[var(--color-border)] bg-white">
      <div
        class="max-w-3xl mx-auto prose prose-neutral prose-lg max-w-none text-[var(--color-text)] prose-p:text-[18px] prose-p:leading-relaxed prose-headings:text-[var(--color-heading)] prose-a:text-[var(--color-link)]"
      >
        <div class="whitespace-pre-line">{d.body}</div>
      </div>
    </section>
  )}

  <!-- Equipe -->
  {team.length > 0 && (
    <section class="px-4 sm:px-6 py-14 md:py-20 bg-[var(--color-surface)]" aria-labelledby="sobre-equipe">
      <div class="max-w-5xl mx-auto">
        <h2 id="sobre-equipe" class="text-2xl md:text-3xl font-bold text-[var(--color-heading)] mb-10 text-center">
          {teamSectionTitle}
        </h2>
        <div class="grid sm:grid-cols-2 gap-8">
          {team.map((m: any) => (
            <div class="flex gap-5 items-start p-6 md:p-8 rounded-2xl border border-[var(--color-border)] bg-white shadow-sm">
              {m.photo?.trim() ? (
                <img
                  src={resolveBemmaeMediaUrl(m.photo.trim()) || m.photo.trim()}
                  alt={m.name || ''}
                  width="112"
                  height="112"
                  class="shrink-0 w-24 h-24 md:w-28 md:h-28 rounded-2xl object-cover ring-2 ring-[var(--color-border)]"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div
                  class="shrink-0 w-24 h-24 md:w-28 md:h-28 rounded-2xl bg-[var(--color-nude)] flex items-center justify-center text-3xl ring-2 ring-[var(--color-border)]"
                  aria-hidden="true"
                >
                  {m.emoji || '👤'}
                </div>
              )}
              <div class="min-w-0">
                <h3 class="text-lg font-semibold text-[var(--color-heading)]">{m.name}</h3>
                {m.role && <p class="text-sm font-medium text-[var(--color-accent)] mt-1">{m.role}</p>}
                {m.bio && <p class="text-[var(--color-muted)] mt-3 leading-relaxed text-[15px] md:text-base">{m.bio}</p>}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="px-4 sm:px-6 py-14 md:py-20 bg-[var(--color-bg)]">
    <div class="max-w-3xl mx-auto text-center rounded-3xl border border-[var(--color-border)] bg-white p-10 md:p-14 shadow-sm">
      <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-heading)] mb-4">{ctaBannerTitle}</h2>
      <p class="text-[var(--color-muted)] text-lg leading-relaxed mb-8">{ctaBannerText}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a
          href={ctaPrimaryHref}
          class="inline-flex min-h-[48px] items-center justify-center rounded-full bg-[var(--color-accent)] px-8 py-3 text-sm font-semibold text-white hover:opacity-90 transition-opacity w-full sm:w-auto"
        >
          {ctaPrimaryText}
        </a>
        {ctaSecondaryText && ctaSecondaryHref && (
          <a
            href={ctaSecondaryHref}
            class="inline-flex min-h-[48px] items-center justify-center rounded-full border-2 border-[var(--color-border)] px-8 py-3 text-sm font-semibold text-[var(--color-heading)] hover:bg-[var(--color-surface)] transition-colors w-full sm:w-auto"
          >
            {ctaSecondaryText}
          </a>
        )}
      </div>
    </div>
  </section>

  {disclaimer && (
    <p class="max-w-3xl mx-auto px-4 sm:px-6 pb-14 text-center text-sm text-[var(--color-muted)] leading-relaxed">
      {disclaimer}
    </p>
  )}
</div>
