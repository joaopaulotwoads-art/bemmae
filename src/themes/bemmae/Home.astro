---
/**
 * Home Bem Mãe — conteúdo principal; layout (head/header/footer) vem da página.
 */
import { getCollection } from 'astro:content';
import { getPostUrl, type BlogPermalinkStructure, type BlogUrlPrefix } from '../../utils/blog-permalink';
import { resolveBemmaeMediaUrl } from '../../utils/media-url';
interface Props {
  homeData: Record<string, any>;
  latestPosts: any[];
  blogPermalinkStructure: BlogPermalinkStructure;
  blogUrlPrefix: BlogUrlPrefix;
}

const {
  homeData: h,
  latestPosts,
  blogPermalinkStructure,
  blogUrlPrefix,
} = Astro.props;

const categories = await getCollection('categories');
const categoryLabel = (slug: string | undefined) => {
  if (!slug) return '';
  const c = categories.find((x) => x.data.slug === slug);
  return c?.data.name || slug;
};

const heroBg = h.heroBgImage || '/images/bemmae/hero-home.png';
const categoryCards = Array.isArray(h.categoryCards) ? h.categoryCards : [];
const homeHighlights = Array.isArray(h.homeHighlights) ? h.homeHighlights.filter(Boolean) : [];
const aboutText = String(h.aboutText || '').trim();
const showAbout = aboutText.length > 0;
const aboutTitle = String(h.aboutTitle || 'Sobre nós').trim() || 'Sobre nós';
const aboutImg = String(h.aboutImage || '').trim();
/** Foto institucional quando o CMS não define URL (evita coluna vazia). */
const ABOUT_DEFAULT_IMAGE =
  'https://images.unsplash.com/photo-1515488042361-ee00e0ddd4e4?auto=format&fit=crop&w=960&q=80';
const aboutImgSrc = aboutImg || ABOUT_DEFAULT_IMAGE;
const aboutParagraphs = aboutText
  .split(/\n\n+/)
  .map((p) => p.trim())
  .filter(Boolean);

const PLACEHOLDER_THUMB = '/images/bemmae/post-placeholder.svg';

function formatPostDate(iso: string | undefined) {
  if (!iso) return '';
  try {
    return new Date(iso).toLocaleDateString('pt-BR', {
      day: 'numeric',
      month: 'short',
      year: 'numeric',
    });
  } catch {
    return '';
  }
}

/** Ícone de categoria em traço fino (paleta do site via currentColor). */
function categoryIconKind(title: string): 'sun' | 'leaf' | 'heart' | 'layout' {
  const t = title.toLowerCase();
  if (t.includes('rotina')) return 'sun';
  if (t.includes('aliment')) return 'leaf';
  if (t.includes('saúde') || t.includes('saude')) return 'heart';
  return 'layout';
}
---
<article class="bemmae-home">
  <section
    class="relative min-h-[72vh] flex flex-col items-center justify-center bg-cover bg-center pt-20 pb-0 md:pt-28"
    style={`background-image: url('${heroBg}');`}
    aria-labelledby="hero-title"
  >
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: linear-gradient(180deg, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.48) 38%, rgba(0,0,0,0.28) 58%, rgba(255,248,245,0.98) 100%);"
    />
    <div class="relative z-[1] max-w-4xl mx-auto px-4 text-center pb-16 md:pb-20 bemmae-hero-reveal">
      {h.heroKicker && (
        <p class="text-xs sm:text-sm font-semibold tracking-[0.2em] text-white/95 uppercase mb-4 drop-shadow-[0_1px_4px_rgba(0,0,0,0.5)]">
          {h.heroKicker}
        </p>
      )}
      <h1
        id="hero-title"
        class="hero-home-title font-heading text-[1.75rem] font-black tracking-[-0.02em] text-white leading-[1.12] mb-5 max-w-3xl mx-auto sm:text-4xl md:text-5xl lg:text-[3.35rem]"
        style="text-shadow: 0 2px 4px rgba(0,0,0,0.55), 0 8px 32px rgba(0,0,0,0.35), 0 0 1px rgba(0,0,0,0.6);"
      >
        {h.heroTitle || 'Seu título'}
      </h1>
      {h.heroSubtitle && (
        <p
          class="text-base md:text-xl text-white max-w-2xl mx-auto mb-10 leading-relaxed"
          style="text-shadow: 0 1px 3px rgba(0,0,0,0.45), 0 4px 20px rgba(0,0,0,0.25);"
        >
          {h.heroSubtitle}
        </p>
      )}
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center">
        <a
          href={h.heroCtaPrimaryHref || '/blog'}
          class="inline-flex items-center justify-center min-h-[52px] px-10 py-3.5 rounded-full bg-[var(--color-accent)] text-white text-base font-extrabold tracking-tight hover:brightness-110 active:brightness-95 transition-all shadow-[0_4px_14px_rgba(0,0,0,0.22),0_2px_6px_rgba(255,135,91,0.45)] ring-1 ring-white/25"
        >
          {h.heroCtaPrimaryText || 'Ver artigos'}
        </a>
        <a
          href={h.heroCtaSecondaryHref || '/sobre'}
          class="inline-flex items-center justify-center min-h-[48px] px-8 py-3 rounded-full border-2 border-white/90 text-white font-semibold hover:bg-white/15 transition-colors backdrop-blur-[2px]"
        >
          {h.heroCtaSecondaryText || 'Quem somos'}
        </a>
      </div>
    </div>
    <div class="relative z-[1] w-full mt-auto" aria-hidden="true">
      <svg
        class="block w-full h-[48px] sm:h-[64px] text-[var(--color-bg)]"
        viewBox="0 0 1440 64"
        preserveAspectRatio="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          fill="currentColor"
          d="M0,32 C240,64 480,0 720,32 C960,64 1200,0 1440,32 L1440,64 L0,64 Z"
        />
      </svg>
    </div>
  </section>

  {homeHighlights.length > 0 && (
    <div class="relative z-[2] -mt-4 px-4 sm:px-6 max-w-5xl mx-auto mb-12">
      <ul
        class="flex flex-col sm:flex-row flex-wrap items-stretch justify-center gap-3 sm:gap-4 text-sm text-[var(--color-heading)]"
      >
        {homeHighlights.map((line: string) => (
          <li
            class="flex-1 min-w-[200px] flex items-center gap-3 rounded-2xl bg-white/90 px-4 py-3 shadow-md shadow-stone-900/5 ring-1 ring-stone-900/[0.06] backdrop-blur-sm"
          >
            <span
              class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-[var(--color-border)] bg-white text-[var(--color-accent)]"
              aria-hidden="true"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
            </span>
            <span class="font-medium leading-snug text-[var(--color-heading)]">{line}</span>
          </li>
        ))}
      </ul>
    </div>
  )}

  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    {categoryCards.length > 0 && (
      <section class="mb-16 md:mb-20" aria-labelledby="categorias-title">
        <div class="text-center max-w-2xl mx-auto mb-10">
          <h2 id="categorias-title" class="font-heading text-2xl md:text-3xl font-bold tracking-tight text-[var(--color-heading)]">
            {h.categoriesSectionTitle || 'O que você encontra aqui'}
          </h2>
          <p class="mt-2 text-[var(--color-muted)] text-[15px] leading-relaxed">
            Três frentes que guiam o conteúdo do blog: escolha por tema ou explore os artigos mais recentes abaixo.
          </p>
        </div>
        <div class="grid md:grid-cols-3 gap-5 md:gap-6">
          {categoryCards.map((c: any) => (
            <a
              href={c.href || '/blog'}
              class="group bemmae-home-cat-card block p-6 md:p-7 rounded-2xl border border-[var(--color-border)] bg-white shadow-[0_1px_3px_rgba(0,0,0,0.04),0_4px_14px_rgba(0,0,0,0.04)] hover:shadow-[0_4px_20px_rgba(0,0,0,0.06)] hover:-translate-y-0.5 hover:border-[var(--color-accent)]/35 transition-all duration-300"
            >
              <div
                class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-accent)]"
                aria-hidden="true"
              >
                {categoryIconKind(String(c.title || '')) === 'sun' && (
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4">
                    <circle cx="12" cy="12" r="3.5" />
                    <path stroke-linecap="round" d="M12 2v1.5M12 20.5V22M4.22 4.22l1.06 1.06M18.72 18.72l1.06 1.06M2 12h1.5M20.5 12H22M4.22 19.78l1.06-1.06M18.72 5.28l1.06-1.06" />
                  </svg>
                )}
                {categoryIconKind(String(c.title || '')) === 'leaf' && (
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 21c-4.5-4-7-8.5-7-13a7 7 0 0114 0c0 4.5-2.5 9-7 13z" />
                    <path stroke-linecap="round" d="M12 21V11" />
                  </svg>
                )}
                {categoryIconKind(String(c.title || '')) === 'heart' && (
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                  </svg>
                )}
                {categoryIconKind(String(c.title || '')) === 'layout' && (
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75A2.25 2.25 0 0115.75 13.5H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25zM13.5 6A2.25 2.25 0 0115.75 3.75H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25A2.25 2.25 0 0113.5 8.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25z" />
                  </svg>
                )}
              </div>
              <h3 class="font-heading font-bold text-lg text-[var(--color-heading)] group-hover:text-[var(--color-link)] transition-colors">
                {c.title}
              </h3>
              {c.description && <p class="text-sm text-[var(--color-muted)] mt-2 leading-relaxed">{c.description}</p>}
              <span class="inline-flex items-center gap-1 mt-4 text-sm font-semibold text-[var(--color-accent)] opacity-90 group-hover:opacity-100">
                Ver artigos <span aria-hidden="true">→</span>
              </span>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="mb-16 md:mb-20" aria-labelledby="posts-title">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8 md:mb-10">
        <div class="max-w-2xl">
          <h2 id="posts-title" class="font-heading text-2xl md:text-3xl font-bold tracking-tight text-[var(--color-heading)]">
            {h.latestPostsTitle || 'Últimos artigos'}
          </h2>
          {(h.latestPostsSubtitle || '').trim() && (
            <p class="mt-2 text-[var(--color-muted)] text-[15px] md:text-base leading-relaxed">
              {String(h.latestPostsSubtitle).trim()}
            </p>
          )}
        </div>
      </div>
      {latestPosts.length === 0 ? (
        <p class="text-sm text-[var(--color-muted)]">{h.emptyLatestText || 'Nenhum artigo publicado ainda.'}</p>
      ) : (
        <>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-7">
            {latestPosts.map((post) => {
              const url = getPostUrl(post, blogPermalinkStructure, blogUrlPrefix);
              const thumb = resolveBemmaeMediaUrl(post.data.thumbnail || post.data.metaImage);
              const dateStr = formatPostDate(post.data.publishedDate);
              const catStr = categoryLabel(post.data.category);
              return (
                <a
                  href={url}
                  class="group bemmae-home-post-card flex flex-col overflow-hidden rounded-[20px] border border-[#eeeeee] bg-white shadow-[0_2px_10px_rgba(0,0,0,0.04)] transition-[transform,box-shadow] duration-300 ease-out hover:-translate-y-[5px] hover:shadow-[0_14px_32px_-10px_rgba(0,0,0,0.14),0_6px_14px_-4px_rgba(0,0,0,0.06)]"
                >
                  <!-- Área da imagem: branco puro, 4:3, contain -->
                  <div class="relative flex aspect-[4/3] w-full items-center justify-center overflow-hidden bg-white p-3 md:p-4">
                    {catStr && (
                      <span
                        class="absolute left-3 top-3 z-10 inline-flex max-w-[calc(100%-1.5rem)] items-center gap-1.5 rounded-full border border-[#eeeeee] bg-white px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wide text-[#374151] shadow-sm"
                        aria-label={`Categoria: ${catStr}`}
                      >
                        <svg
                          class="h-3.5 w-3.5 shrink-0 text-[var(--color-accent)]"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                          stroke-width="1.5"
                          aria-hidden="true"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"
                          />
                        </svg>
                        <span class="truncate">{catStr}</span>
                      </span>
                    )}
                    {thumb ? (
                      <img
                        src={thumb}
                        alt=""
                        class="max-h-full max-w-full object-contain transition-opacity duration-300 group-hover:opacity-95"
                        loading="lazy"
                        decoding="async"
                        onerror={`this.onerror=null;this.src='${PLACEHOLDER_THUMB}'`}
                      />
                    ) : (
                      <img
                        src={PLACEHOLDER_THUMB}
                        alt=""
                        class="max-h-full max-w-full object-contain opacity-90"
                        loading="lazy"
                        decoding="async"
                      />
                    )}
                  </div>
                  <!-- Corpo: fundo pêssego clarinho -->
                  <div class="flex flex-1 flex-col bg-[#fff5f0] px-4 py-4 md:px-5 md:py-5">
                    {dateStr && (
                      <div class="mb-2 flex flex-wrap items-center gap-1.5 text-xs font-medium text-[#525252]">
                        <svg
                          class="h-3.5 w-3.5 shrink-0 text-[#737373]"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                          stroke-width="1.5"
                          aria-hidden="true"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5a2.25 2.25 0 002.25-2.25m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5a2.25 2.25 0 012.25 2.25v7.5"
                          />
                        </svg>
                        <time datetime={post.data.publishedDate}>{dateStr}</time>
                      </div>
                    )}
                    <h3 class="font-heading line-clamp-3 text-[1.05rem] font-bold leading-[1.3] text-[#121212] md:text-lg">
                      {post.data.title}
                    </h3>
                    {post.data.metaDescription && (
                      <p class="mt-2 line-clamp-2 flex-1 text-sm leading-relaxed text-[#525252]">
                        {post.data.metaDescription}
                      </p>
                    )}
                    <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-link)] transition-colors group-hover:text-[var(--color-accent)]">
                      Ler análise completa
                      <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
                    </span>
                  </div>
                </a>
              );
            })}
          </div>
          <p class="mt-10 text-center">
            <a
              href="/blog"
              class="inline-flex items-center justify-center min-h-[48px] px-8 py-3 rounded-full bg-[var(--color-accent)] text-white text-sm font-semibold hover:brightness-105 shadow-md transition-all"
            >
              {h.latestPostsCtaText || 'Ver todos os artigos'}
            </a>
          </p>
        </>
      )}
    </section>
  </div>

  {showAbout && (
    <section
      class="scroll-mt-24 bg-[#fdf6f2] py-16 md:py-20 mb-0"
      aria-labelledby="about-section-title"
    >
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="rounded-3xl border border-[var(--color-border)] bg-white p-8 sm:p-10 lg:p-12 shadow-[0_1px_3px_rgba(0,0,0,0.04),0_8px_24px_-6px_rgba(0,0,0,0.06)]">
        <div class="grid grid-cols-1 lg:grid-cols-2 lg:gap-12 xl:gap-14 items-center gap-10">
          <div class="order-1 min-w-0 space-y-5">
            <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-accent)]">Sobre o projeto</p>
            <h2
              id="about-section-title"
              class="font-heading text-2xl md:text-3xl font-bold tracking-tight text-[var(--color-heading)]"
            >
              {aboutTitle}
            </h2>
            {aboutParagraphs.map((para) => (
              <p class="text-[var(--color-text)] text-[17px] leading-relaxed">{para}</p>
            ))}
            {(h.aboutCtaText || h.aboutCtaHref) && (
              <div class="pt-2">
                <a
                  href={String(h.aboutCtaHref || '/sobre').trim() || '/sobre'}
                  class="inline-flex min-h-[44px] items-center justify-center rounded-full border-2 border-[var(--color-accent)] px-6 py-2.5 text-sm font-semibold text-[var(--color-accent)] hover:bg-[var(--color-accent)] hover:text-white transition-colors"
                >
                  {h.aboutCtaText || 'Conheça mais'}
                </a>
              </div>
            )}
          </div>
          <figure class="order-2 w-full max-w-md mx-auto lg:max-w-none lg:mx-0">
            <div class="aspect-[4/5] overflow-hidden rounded-2xl bg-[var(--color-surface)] shadow-xl ring-1 ring-stone-900/10">
              <img
                src={aboutImgSrc}
                alt={aboutTitle}
                class="h-full w-full object-cover object-center"
                loading="lazy"
                decoding="async"
                width="640"
                height="800"
              />
            </div>
          </figure>
        </div>
      </div>
      </div>
    </section>
  )}

  <div class="bg-[#fdf6f2] py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <section
      class="rounded-3xl border border-[var(--color-border)] bg-white p-8 md:p-10 text-center shadow-[0_1px_3px_rgba(0,0,0,0.04),0_8px_24px_-6px_rgba(0,0,0,0.06)]"
      aria-labelledby="newsletter-title"
    >
      <h2 id="newsletter-title" class="font-heading text-2xl md:text-3xl font-bold tracking-tight text-[var(--color-heading)] mb-2">
        {h.newsletterTitle || 'Newsletter'}
      </h2>
      <p class="text-sm md:text-[15px] text-[var(--color-muted)] mb-6 max-w-lg mx-auto leading-relaxed">
        {h.newsletterDescription || ''}
      </p>
      <form class="flex flex-col sm:flex-row gap-3 justify-center max-w-md mx-auto" action="#" method="post" aria-label="Newsletter">
        <label for="newsletter-email" class="sr-only">E-mail</label>
        <input
          id="newsletter-email"
          type="email"
          name="email"
          placeholder={h.newsletterPlaceholder || 'seu@email.com'}
          class="flex-1 min-h-[48px] px-4 rounded-xl border border-[var(--color-border)] bg-white text-[var(--color-text)] shadow-inner focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]/40"
          required
        />
        <button
          type="submit"
          class="min-h-[48px] px-6 py-2.5 rounded-xl bg-[var(--color-accent)] text-white text-sm font-semibold hover:brightness-105 shadow-md transition-all"
        >
          {h.newsletterButtonText || 'Inscrever'}
        </button>
      </form>
    </section>
    </div>
  </div>
</article>
