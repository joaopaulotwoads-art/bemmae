---
import { getPostUrl, type BlogPermalinkStructure, type BlogUrlPrefix } from '../../utils/blog-permalink';
import { resolveBemmaeMediaUrl } from '../../utils/media-url';

interface Props {
  posts: any[];
  blogData: Record<string, any>;
  blogPermalinkStructure: BlogPermalinkStructure;
  blogUrlPrefix: BlogUrlPrefix;
  /** Nome legível da categoria (quando ?categoria= está na URL). */
  categoryName?: string;
  /** True se havia parâmetro categoria na URL (mesmo sem posts). */
  categoryFilterActive?: boolean;
  /** Slug da categoria na query (?categoria=) para preservar na busca. */
  categorySlug?: string;
  /** Termo atual ?q= (normalizado). */
  searchQuery?: string;
}

const {
  posts,
  blogData: b,
  blogPermalinkStructure,
  blogUrlPrefix,
  categoryName,
  categoryFilterActive,
  categorySlug,
  searchQuery,
} = Astro.props;
const showCategoryHeading = Boolean(categoryName);
const showUnknownCategory = Boolean(categoryFilterActive && !categoryName);
const hasSearch = Boolean(searchQuery);

const blogListSearchAction = '/blog';
const clearSearchHref = categorySlug
  ? `${blogListSearchAction}?${new URLSearchParams({ categoria: categorySlug }).toString()}`
  : blogListSearchAction;
---
<article class="max-w-4xl mx-auto px-4 py-12">
  <header class="mb-10">
    <h1 class="font-heading text-3xl font-extrabold tracking-tight text-[var(--color-heading)] md:text-4xl">
      {showCategoryHeading ? categoryName : showUnknownCategory ? 'Categoria' : b.pageTitle || 'Blog'}
    </h1>
    {showCategoryHeading && (
      <p class="mt-2">
        <a href="/blog" class="text-sm font-medium text-[var(--color-link)] no-underline hover:underline">Ver todos os artigos</a>
      </p>
    )}
    {!showCategoryHeading && !showUnknownCategory && (b.heroDescription || b.blogIntro) && (
      <p class="mt-1 text-[var(--color-muted)]">{b.heroDescription || b.blogIntro}</p>
    )}
    <form
      id="buscar"
      method="get"
      action={blogListSearchAction}
      class="mt-6 flex scroll-mt-24 flex-col gap-2 sm:flex-row sm:items-center"
      role="search"
      aria-label="Buscar artigos do blog"
    >
      {categorySlug ? <input type="hidden" name="categoria" value={categorySlug} /> : null}
      <div class="relative flex-1 min-w-0 max-w-xl">
        <label for="blog-list-search" class="sr-only">Buscar no blog</label>
        <input
          id="blog-list-search"
          type="search"
          name="q"
          value={searchQuery || ''}
          placeholder="Buscar artigos…"
          autocomplete="off"
          class="w-full rounded-lg border border-[var(--color-border)] bg-white px-3 py-2.5 pr-10 text-[var(--color-dark)] placeholder:text-[var(--color-muted)] shadow-sm focus:border-[var(--color-link)] focus:outline-none focus:ring-2 focus:ring-[var(--color-link)]/25"
        />
        <span class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-[var(--color-muted)]" aria-hidden="true">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </span>
      </div>
      <button
        type="submit"
        class="shrink-0 rounded-lg bg-[var(--color-primary,#ff875b)] px-4 py-2.5 text-sm font-semibold text-white hover:opacity-95"
      >
        Buscar
      </button>
    </form>
    {hasSearch && (
      <p class="mt-3 text-sm text-[var(--color-muted)]">
        {posts.length === 0
          ? `Nenhum artigo encontrado para “${searchQuery}”.`
          : `${posts.length} resultado${posts.length === 1 ? '' : 's'} para “${searchQuery}”.`}{' '}
        <a href={clearSearchHref} class="font-medium text-[var(--color-link)] no-underline hover:underline">
          Limpar busca
        </a>
      </p>
    )}
  </header>
  {posts.length === 0 ? (
    <p class="text-[var(--color-muted)]">
      {hasSearch ? `Tente outras palavras ou veja todos os artigos na página do blog.` : b.emptyMessage || 'Nenhum post publicado ainda.'}
    </p>
  ) : (
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
      {posts.map((post, idx) => {
        const url = getPostUrl(post, blogPermalinkStructure, blogUrlPrefix);
        const thumb = resolveBemmaeMediaUrl(post.data.thumbnail || post.data.metaImage);
        const date = post.data.publishedDate;
        return (
          <a
            href={url}
            class="group block rounded-lg border border-[var(--color-border)] bg-white overflow-hidden hover:border-[var(--color-link)] transition-colors"
          >
            {thumb ? (
              <div class="aspect-[4/3] overflow-hidden bg-[var(--color-surface)]">
                <img
                  src={thumb}
                  alt=""
                  width="800"
                  height="600"
                  sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                  class="w-full h-full object-cover"
                  loading={idx === 0 ? 'eager' : 'lazy'}
                  fetchpriority={idx === 0 ? 'high' : 'auto'}
                  decoding="async"
                />
              </div>
            ) : (
              <div class="aspect-[4/3] bg-[var(--color-surface)] flex items-center justify-center text-[var(--color-muted)] text-sm">Sem capa</div>
            )}
            <div class="p-4">
              {date && (
                <time class="text-xs text-[var(--color-muted)]" datetime={date}>
                  {new Date(date).toLocaleDateString('pt-BR')}
                </time>
              )}
              <h2 class="font-heading mt-1 text-lg font-semibold text-[var(--color-heading)] group-hover:text-[var(--color-link)]">{post.data.title}</h2>
              {post.data.metaDescription && (
                <p class="text-sm text-[var(--color-muted)] mt-1 line-clamp-2">{post.data.metaDescription}</p>
              )}
            </div>
          </a>
        );
      })}
    </div>
  )}
</article>
