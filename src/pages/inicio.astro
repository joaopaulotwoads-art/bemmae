---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';
---
<BaseLayout title="Início" description={siteConfig.description}>
  <div class="max-w-xl mx-auto px-4 py-16 text-center">
    <p class="text-[var(--color-muted)] mb-4">Redirecionando para a página inicial.</p>
    <a href="/" class="inline-flex items-center justify-center min-h-[44px] px-5 py-2.5 rounded-md bg-[var(--color-accent)] text-white font-medium">Ir para início</a>
  </div>
</BaseLayout>
