---
/**
 * [...slug].astro
 *
 * Com blogUrlPrefix = root:
 * - Posts: /slug-do-post | /2025/03/slug
 * - Categorias: /carrinhos-de-bebe (lista filtrada; id da categoria = segmento da URL)
 */

import { getCollection, getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayoutBemmae from '../themes/bemmae/BaseLayout.astro';
import BemMaeBlogPost from '../themes/bemmae/BlogPost.astro';
import BemMaeBlogList from '../themes/bemmae/BlogList.astro';
import { logoSrcFromMenu } from '../utils/theme-nav';
import { buildPostPath, type BlogPermalinkStructure } from '../utils/blog-permalink';
import { loadBlogPageData } from '../utils/load-blog-page-data';

export const prerender = true;

export async function getStaticPaths() {
  const reservedTopLevel = new Set([
    'sobre',
    'contato',
    'blog',
    'admin',
    'authors',
    'api',
    'termos',
    'politica-de-cookies',
    'servicos',
    'lp1',
    'curso-vendas',
    'setup',
    'cnx-blog-resolve',
  ]);

  const settings = await getEntry('siteSettings', 'settings').catch(() => null);
  const prefix = (settings?.data?.blogUrlPrefix as string) || 'blog';

  if (prefix !== 'root') return [];

  const posts = await getCollection('posts');
  const structure = (settings?.data?.blogPermalinkStructure as BlogPermalinkStructure) || 'postname';
  const slugReservedForStaticPages = new Set(['sobre', 'contato']);

  const postPaths = posts
    .filter((post) => !slugReservedForStaticPages.has(post.data.slug || post.id))
    .map((post) => ({
      params: {
        slug: buildPostPath({ ...post, data: { ...post.data, slug: post.data.slug || post.id } }, structure),
      },
      props: { kind: 'post' as const, post },
    }));

  const postSlugSet = new Set(postPaths.map((p) => p.params.slug));

  const categories = await getCollection('categories');
  const categoryPaths = categories
    .filter((c) => {
      const id = c.id;
      if (!id || id.includes('/')) return false;
      if (postSlugSet.has(id)) return false;
      if (slugReservedForStaticPages.has(id)) return false;
      if (reservedTopLevel.has(id)) return false;
      return true;
    })
    .map((category) => ({
      params: { slug: category.id },
      props: { kind: 'category' as const, category },
    }));

  return [...postPaths, ...categoryPaths];
}

type Props =
  | { kind: 'post'; post: CollectionEntry<'posts'> }
  | { kind: 'category'; category: CollectionEntry<'categories'> };

const props = Astro.props as Props;

const d = await loadBlogPageData(props, Astro.url.pathname, Astro.url.origin);
const {
  useBemmae,
  layoutType,
  siteName,
  beMenu,
  beFootNav,
  beNav,
  publicSiteUrl,
  post,
  Content,
  htmlContent,
  author,
  documentTitle,
  ogImageAbs,
  articleIso,
  postJsonLd,
  category,
  publishedPosts,
  beBlog,
  pageDesc,
  blogPermalinkStructure,
  blogUrlPrefix,
  relatedPosts,
  blogPermalinkStructureResolved,
  blogUrlPrefixResolved,
  bemmaeArticleExperts,
  bemmaeArticleExpertsSectionTitle,
} = d;
---

{
  props.kind === 'post' && post ? (
    <BaseLayoutBemmae
      title={documentTitle}
      description={post.data.metaDescription || ''}
      siteName={(beMenu as { logoText?: string } | null)?.logoText || siteName}
      logoSrc={logoSrcFromMenu(beMenu as Record<string, unknown>)}
      siteUrl={publicSiteUrl}
      nav={beNav}
      footerNav={beFootNav}
      contentThemeId="bemmae"
      ogType="article"
      ogImageAbs={ogImageAbs}
      articlePublishedTime={articleIso}
      articleModifiedTime={articleIso}
      extraJsonLd={postJsonLd}
    >
      <BemMaeBlogPost
        post={post}
        author={author}
        Content={Content}
        htmlContent={htmlContent}
        relatedPosts={relatedPosts}
        blogPermalinkStructure={blogPermalinkStructureResolved}
        blogUrlPrefix={blogUrlPrefixResolved}
        articleExperts={bemmaeArticleExperts}
        articleExpertsSectionTitle={bemmaeArticleExpertsSectionTitle}
      />
    </BaseLayoutBemmae>
  ) : null
}

{
  props.kind === 'category' && category ? (
    <BaseLayoutBemmae
      title={`${category.data.name} - ${siteName}`}
      description={pageDesc}
      siteName={(beMenu as { logoText?: string } | null)?.logoText || siteName}
      logoSrc={logoSrcFromMenu(beMenu as Record<string, unknown>)}
      siteUrl={publicSiteUrl}
      nav={beNav}
      footerNav={beFootNav}
      contentThemeId="bemmae"
    >
      <BemMaeBlogList
        posts={publishedPosts}
        blogData={beBlog}
        blogPermalinkStructure={blogPermalinkStructure}
        blogUrlPrefix={blogUrlPrefix}
        categoryName={category.data.name}
        categoryFilterActive={true}
      />
    </BaseLayoutBemmae>
  ) : null
}
