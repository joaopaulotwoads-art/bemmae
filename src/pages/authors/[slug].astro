---
import { getCollection, getEntry } from 'astro:content';
import BaseLayoutBemmae from '../../themes/bemmae/BaseLayout.astro';
import BemMaeAuthorPage from '../../themes/bemmae/AuthorPage.astro';
import { readSingleton } from '../../utils/singleton-utils';
import { footerNavFromSingleton, logoSrcFromMenu, navFromMenu } from '../../utils/theme-nav';
import { resolvePublicSiteUrl } from '../../utils/read-site-settings';
import { getPostUrl, type BlogPermalinkStructure } from '../../utils/blog-permalink';

export const prerender = true;

export async function getStaticPaths() {
  const authors = await getCollection('authors');
  return authors.map((author) => ({
    params: { slug: author.id },
    props: { author },
  }));
}

const { author } = Astro.props;

const allPosts = await getCollection('posts');
const authorPosts = allPosts
  .filter((post) => post.data.author === author.id)
  .sort((a, b) => (b.data.publishedDate || '').localeCompare(a.data.publishedDate || ''));

const settings = await getEntry('siteSettings', 'settings').catch(() => null);
const blogPermalinkStructure = (settings?.data?.blogPermalinkStructure as BlogPermalinkStructure) || 'postname';
const blogUrlPrefix = (settings?.data?.blogUrlPrefix as import('../../utils/blog-permalink').BlogUrlPrefix) || 'blog';

const siteName = settings?.data?.siteName || 'Site';
const siteUrl = resolvePublicSiteUrl(settings?.data?.canonicalUrl as string | undefined, Astro.url.origin);
const beMenu = await readSingleton('menu', 'bemmae');
const beFoot = await readSingleton('footer', 'bemmae');
const beNav = beMenu ? navFromMenu(beMenu) : [];
const beFootNav = beFoot ? footerNavFromSingleton(beFoot) : [];
const categories = await getCollection('categories');

const rawBio = String(author.data.bio || '').trim();
const pageDescription =
  rawBio.length > 165 ? `${rawBio.slice(0, 162).trim()}…` : rawBio || `Artigos de ${author.data.name} no ${siteName}`;
---

<BaseLayoutBemmae
  title={`${author.data.name} - ${siteName}`}
  description={pageDescription}
  siteName={(beMenu as { logoText?: string } | null)?.logoText || siteName}
  logoSrc={logoSrcFromMenu(beMenu as Record<string, unknown>)}
  siteUrl={siteUrl}
  nav={beNav}
  footerNav={beFootNav}
  contentThemeId="bemmae"
>
  <BemMaeAuthorPage
    author={author}
    posts={authorPosts}
    blogPermalinkStructure={blogPermalinkStructure}
    blogUrlPrefix={blogUrlPrefix}
    categories={categories}
  />
</BaseLayoutBemmae>
