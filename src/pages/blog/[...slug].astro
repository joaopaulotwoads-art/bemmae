---
/**
 * blog/[...slug].astro
 *
 * Página individual de post com suporte a estrutura de permalink configurável.
 * Aceita: /blog/nome-post | /blog/2025/03/nome-post | /blog/2025/03/04/nome-post
 * Usa layout conforme siteMode: local → LocalLayout, blog → MainLayout.
 */

import { getCollection, getEntry, render } from 'astro:content';
import BaseLayoutBemmae from '../../themes/bemmae/BaseLayout.astro';
import BemMaeBlogPost from '../../themes/bemmae/BlogPost.astro';
import { readSingleton } from '../../utils/singleton-utils';
import { footerNavFromSingleton, logoSrcFromMenu, navFromMenu } from '../../utils/theme-nav';
import { readPost } from '../../utils/post-utils';
import { buildPostPath, getPostUrl, type BlogPermalinkStructure, type BlogUrlPrefix } from '../../utils/blog-permalink';
import { pickRelatedPosts } from '../../utils/related-posts';
import { readSiteSettings, resolvePublicSiteUrl, buildCanonicalPageUrl } from '../../utils/read-site-settings';
import {
  buildAuthorAbsoluteUrl,
  buildPostJsonLd,
  toAbsoluteUrl,
  toIsoDateTime,
} from '../../utils/post-json-ld';
import { resolveBemmaeMediaUrl } from '../../utils/media-url';
import { buildBemmaeArticleExperts } from '../../utils/bemmae-article-experts';
import { buildBemmaePostDocumentTitle } from '../../utils/post-document-title';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const settings = await getEntry('siteSettings', 'settings').catch(() => null);
  const structure = (settings?.data?.blogPermalinkStructure as BlogPermalinkStructure) || 'postname';
  const prefix = (settings?.data?.blogUrlPrefix as string) || 'blog';

  // Só gera paths com /blog quando o prefixo for 'blog'
  if (prefix !== 'blog') return [];

  return posts.map(post => ({
    params: { slug: buildPostPath({ ...post, data: { ...post.data, slug: post.data.slug || post.id } }, structure) },
    props: { post },
  }));
}

const { slug } = Astro.params;
const { post } = Astro.props;

if (!post) return Astro.redirect('/404');

const slugKey = post.data.slug || post.id;
const postFile = await readPost(slugKey);
const htmlContent =
  post.data.contentFormat === 'html' && postFile?.content?.trim()
    ? postFile.content.trim()
    : null;

let Content: (() => unknown) | undefined;
if (!htmlContent) {
  const r = await render(post);
  Content = r.Content;
}

const author = post.data.author ? await getEntry('authors', post.data.author) : null;

const settings = await getEntry('siteSettings', 'settings').catch(() => null);
const siteName = settings?.data?.siteName || 'Site';
const beMenu = await readSingleton('menu', 'bemmae');
const beFoot = await readSingleton('footer', 'bemmae');
const beNav = beMenu ? navFromMenu(beMenu) : [];
const beFootNav = beFoot ? footerNavFromSingleton(beFoot) : [];
const metaTitleTrim = post.data.metaTitle?.trim();
const displayBrand = (beMenu as { logoText?: string } | null)?.logoText || siteName;
const documentTitle = useBemmae
  ? buildBemmaePostDocumentTitle({
      metaTitle: metaTitleTrim,
      postTitle: post.data.title,
      siteName,
      brandName: displayBrand,
    })
  : metaTitleTrim
    ? metaTitleTrim
    : `${post.data.title} - ${siteName}`;

const siteCfg = await readSiteSettings();
const publicSiteUrl = resolvePublicSiteUrl(siteCfg.canonicalUrl as string | undefined, Astro.url.origin);
const pageUrl = buildCanonicalPageUrl(publicSiteUrl, Astro.url.pathname);
const rawPostImg = post.data.metaImage || post.data.thumbnail;
const ogImageAbs = toAbsoluteUrl(publicSiteUrl, resolveBemmaeMediaUrl(rawPostImg) || rawPostImg);
const articleIso = toIsoDateTime(post.data.publishedDate);
let categoryName: string | undefined;
let categoryPath: string | undefined;
if (post.data.category) {
  const cat = await getEntry('categories', post.data.category).catch(() => null);
  if (cat) {
    categoryName = cat.data.name;
    categoryPath = `/${cat.id}`;
  }
}

const blogPermalinkStructure = (settings?.data?.blogPermalinkStructure as BlogPermalinkStructure) || 'postname';
const blogUrlPrefix = (settings?.data?.blogUrlPrefix as BlogUrlPrefix) || 'blog';
const allPosts = await getCollection('posts');
const relatedPosts = useBemmae ? pickRelatedPosts(post, allPosts, 3) : [];
const relatedPostUrls = useBemmae
  ? relatedPosts.map((p) =>
      buildCanonicalPageUrl(
        publicSiteUrl,
        getPostUrl(
          { ...p, data: { ...p.data, slug: p.data.slug || p.id } },
          blogPermalinkStructure,
          blogUrlPrefix,
        ),
      ),
    )
  : [];

const kw = post.data.keywords;
const keywordsStr = Array.isArray(kw)
  ? kw.map((s) => s.trim()).filter(Boolean).join(', ')
  : typeof kw === 'string'
    ? kw.trim()
    : undefined;

const authorAvatarRaw = author?.data?.avatar;
const authorImageAbs =
  author && authorAvatarRaw
    ? toAbsoluteUrl(publicSiteUrl, resolveBemmaeMediaUrl(authorAvatarRaw) || authorAvatarRaw)
    : undefined;

const postJsonLd = useBemmae
  ? buildPostJsonLd({
      seoSchema: post.data.seoSchema,
      headline: post.data.title,
      description: post.data.metaDescription || '',
      pageUrl,
      siteUrl: publicSiteUrl,
      siteName: (beMenu as { logoText?: string } | null)?.logoText || siteName,
      publishedDate: post.data.publishedDate,
      imageUrl: ogImageAbs,
      authorName: author?.data?.name,
      authorUrl: author ? buildAuthorAbsoluteUrl(publicSiteUrl, author.id) : undefined,
      authorImageUrl: authorImageAbs,
      authorJobTitle: author?.data?.jobTitle?.trim() || author?.data?.role,
      authorDescription: author?.data?.seoDescription?.trim() || author?.data?.bio,
      authorSameAs: author?.data?.sameAs,
      htmlContent,
      categoryName,
      categoryPath,
      keywords: keywordsStr || undefined,
      relatedPostUrls: relatedPostUrls.length ? relatedPostUrls : undefined,
    })
  : null;

const beAbout = useBemmae ? await readSingleton('about', 'bemmae') : null;
const articleExperts = useBemmae ? buildBemmaeArticleExperts(author, beAbout as Record<string, unknown> | null) : undefined;
const articleExpertsSectionTitle = useBemmae
  ? String((beAbout as Record<string, unknown> | null)?.teamSectionTitle || 'Conheça nossos especialistas').trim()
  : '';
---

<BaseLayoutBemmae
    title={documentTitle}
    description={post.data.metaDescription || ''}
    siteName={(beMenu as any)?.logoText || siteName}
    logoSrc={logoSrcFromMenu(beMenu as Record<string, unknown>)}
    siteUrl={publicSiteUrl}
    nav={beNav}
    footerNav={beFootNav}
    contentThemeId="bemmae"
    ogType="article"
    ogImageAbs={ogImageAbs}
    articlePublishedTime={articleIso}
    articleModifiedTime={articleIso}
    extraJsonLd={postJsonLd}
>
    <BemMaeBlogPost
      post={post}
      author={author}
      Content={Content}
      htmlContent={htmlContent}
      relatedPosts={relatedPosts}
      blogPermalinkStructure={blogPermalinkStructure}
      blogUrlPrefix={blogUrlPrefix}
      articleExperts={articleExperts}
      articleExpertsSectionTitle={articleExpertsSectionTitle}
    />
</BaseLayoutBemmae>
