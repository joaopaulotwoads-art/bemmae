---
import { getEntry } from 'astro:content';
import BaseLayoutBemmae from '../themes/bemmae/BaseLayout.astro';
import LegalPage from '../themes/bemmae/LegalPage.astro';
import TermosDeUsoContent from '../components/legal/TermosDeUsoContent.astro';
import { readSingleton } from '../utils/singleton-utils';
import { footerNavFromSingleton, logoSrcFromMenu, navFromMenu } from '../utils/theme-nav';
import { resolvePublicSiteUrl } from '../utils/read-site-settings';

const settings = await getEntry('siteSettings', 'settings').catch(() => null);
const siteName = settings?.data?.siteName || 'Site';
const siteUrl = resolvePublicSiteUrl(settings?.data?.canonicalUrl as string | undefined, Astro.url.origin);
const beMenu = await readSingleton('menu', 'bemmae');
const beFoot = await readSingleton('footer', 'bemmae');
const beNav = beMenu ? navFromMenu(beMenu) : [];
const beFootNav = beFoot ? footerNavFromSingleton(beFoot) : [];
---

<BaseLayoutBemmae
    title={`Termos de Uso - ${siteName}`}
    description="Termos e condições de uso deste site."
    siteName={(beMenu as Record<string, string>)?.logoText || siteName}
    logoSrc={logoSrcFromMenu(beMenu as Record<string, unknown>)}
    siteUrl={siteUrl}
    nav={beNav}
    footerNav={beFootNav}
    contentThemeId="bemmae"
>
    <LegalPage title="Termos de Uso">
        <TermosDeUsoContent />
    </LegalPage>
</BaseLayoutBemmae>
