---
import { getCollection, getEntry } from 'astro:content';
import { readSingleton } from '../utils/singleton-utils';
import BaseLayoutBemmae from '../themes/bemmae/BaseLayout.astro';
import BemMaeHome from '../themes/bemmae/Home.astro';
import { footerNavFromSingleton, logoSrcFromMenu, navFromMenu } from '../utils/theme-nav';
import { resolvePublicSiteUrl } from '../utils/read-site-settings';

const settings = await getEntry('siteSettings', 'settings').catch(() => null);

const home = await readSingleton('home', 'bemmae') || {};

const latestPosts = await getCollection('posts').then((posts: any[]) =>
    posts
        .filter((p: any) => p.data.publishedDate)
        .sort((a: any, b: any) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime())
        .slice(0, 12)
);

const blogPermalinkStructure = (settings?.data?.blogPermalinkStructure as import('../utils/blog-permalink').BlogPermalinkStructure) || 'postname';
const blogUrlPrefix = (settings?.data?.blogUrlPrefix as import('../utils/blog-permalink').BlogUrlPrefix) || 'blog';

const siteName = settings?.data?.siteName || 'Site';
const siteUrl = resolvePublicSiteUrl(settings?.data?.canonicalUrl as string | undefined, Astro.url.origin);

const bemmaeMenu = await readSingleton('menu', 'bemmae');
const bemmaeFooter = await readSingleton('footer', 'bemmae');
const bemmaeNav = bemmaeMenu ? navFromMenu(bemmaeMenu) : [];
const bemmaeFooterNav = bemmaeFooter ? footerNavFromSingleton(bemmaeFooter) : [];
const homeRec = (home || {}) as Record<string, string>;
const bemmaeHomeTitle =
    String(homeRec.metaTitle || '').trim() ||
    String(homeRec.heroTitle || '').trim() ||
    siteName;
const bemmaeHomeDescription =
    String(homeRec.metaDescription || '').trim() ||
    String(homeRec.heroSubtitle || '').trim() ||
    '';
---

<BaseLayoutBemmae
    title={bemmaeHomeTitle}
    description={bemmaeHomeDescription}
    siteName={(bemmaeMenu as any)?.logoText || siteName}
    logoSrc={logoSrcFromMenu(bemmaeMenu as Record<string, unknown>)}
    siteUrl={siteUrl}
    nav={bemmaeNav}
    footerNav={bemmaeFooterNav}
    contentThemeId="bemmae"
>
    <BemMaeHome
        homeData={home || {}}
        latestPosts={latestPosts}
        blogPermalinkStructure={blogPermalinkStructure}
        blogUrlPrefix={blogUrlPrefix}
    />
</BaseLayoutBemmae>
