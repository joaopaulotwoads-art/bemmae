---
import { siteConfig } from '../config';
---
<footer class="border-t border-[var(--color-border)] mt-16 bg-[var(--color-nude)]/30">
  <div class="max-w-4xl mx-auto px-4 py-10">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <p class="text-sm text-[var(--color-muted)]">© {new Date().getFullYear()} {siteConfig.name}</p>
      <nav class="flex flex-wrap justify-center gap-6" aria-label="Rodapé">
        {siteConfig.footerNav.map((item) => (
          <a href={item.href} class="text-sm text-[var(--color-muted)] hover:text-[var(--color-accent)] min-h-[44px] flex items-center">{item.label}</a>
        ))}
      </nav>
    </div>
  </div>
</footer>
